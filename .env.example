# ==========================================
# WhatsApp Messaging Platform Configuration
# ==========================================

# 1. Application Settings
# -----------------------
# The external port where the platform will be accessible (Default: 8765)
EXTERNAL_PORT=8765

# The public URL of this platform (Required for Webhooks to work correctly)
# This is the URL where your WhatsApp API server will send delivery reports.
# Example: https://my-whatsapp-platform.com or http://YOUR_SERVER_IP:8765
APP_URL=http://localhost:8765


# 2. WhatsApp API Server Settings
# -------------------------------
# The base URL of your WhatsApp API server (e.g., Evolution API)
# Example: http://192.168.1.100:8080 or https://api.yourdomain.com
WHATSAPP_API_URL=http://localhost:8080

# The API Key / Global API Key for your WhatsApp API server
WHATSAPP_API_KEY=your_api_key_here
